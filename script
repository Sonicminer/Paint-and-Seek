local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function isSeeker(player)
	local character = player.Character
	if character and character:FindFirstChild("SeekerKnife") then
		return true
	end

	local backpack = player:FindFirstChild("Backpack")
	if backpack and backpack:FindFirstChild("SeekerKnife") then
		return true
	end

	return false
end

local function updateESP(player)
	if player == LocalPlayer then
		return
	end

	local character = player.Character
	if not character then
		return
	end

	local head = character:FindFirstChild("Head")
	if not head then
		return
	end

	-- Highlight
	local highlight = character:FindFirstChild("ESPHighlight")
	if not highlight then
		highlight = Instance.new("Highlight")
		highlight.Name = "ESPHighlight"
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.FillTransparency = 0.5
		highlight.OutlineTransparency = 0
		highlight.Parent = character
	end

	-- BillboardGui
	local billboard = head:FindFirstChild("ESPName")
	if not billboard then
		billboard = Instance.new("BillboardGui")
		billboard.Name = "ESPName"
		billboard.Size = UDim2.new(0, 200, 0, 40)
		billboard.StudsOffset = Vector3.new(0, 2.5, 0)
		billboard.AlwaysOnTop = true
		billboard.ResetOnSpawn = false
		billboard.Parent = head
	end

	-- TextLabel
	local label = billboard:FindFirstChild("Label")
	if not label then
		label = Instance.new("TextLabel")
		label.Name = "Label"
		label.Size = UDim2.new(1, 0, 1, 0)
		label.BackgroundTransparency = 1
		label.TextScaled = true
		label.TextStrokeTransparency = 0
		label.Font = Enum.Font.GothamBold
		label.Parent = billboard
	end

	-- Farbe setzen
	if isSeeker(player) then
		highlight.FillColor = Color3.fromRGB(255, 0, 0)
		highlight.OutlineColor = Color3.fromRGB(255, 0, 0)

		label.Text = player.Name .. " [SEEKER]"
		label.TextColor3 = Color3.fromRGB(255, 0, 0)
	else
		highlight.FillColor = Color3.fromRGB(0, 255, 0)
		highlight.OutlineColor = Color3.fromRGB(0, 255, 0)

		label.Text = player.Name
		label.TextColor3 = Color3.fromRGB(0, 255, 0)
	end
end

local function setupPlayer(player)
	if player == LocalPlayer then
		return
	end

	player.CharacterAdded:Connect(function()
		task.wait(1)
		updateESP(player)
	end)

	task.spawn(function()
		while player.Parent do
			updateESP(player)
			task.wait(0.5)
		end
	end)
end

for _, player in ipairs(Players:GetPlayers()) do
	setupPlayer(player)
end

Players.PlayerAdded:Connect(setupPlayer)
